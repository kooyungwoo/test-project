<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.project.sample.mapper.SampleMapper">

    <select id="findAll" resultType="org.example.project.sample.entity.SampleEntity">
        SELECT * FROM SAMPLE_TABLE
    </select>

    <select id="findById" parameterType="int" resultType="org.example.project.sample.entity.SampleEntity">
        SELECT * FROM SAMPLE_TABLE WHERE ID = #{id}
    </select>

    <insert id="insert" parameterType="org.example.project.sample.entity.SampleEntity" useGeneratedKeys="true"
            keyProperty="id">
        INSERT INTO SAMPLE_TABLE(NAME, EMAIL) VALUES(#{name}, #{email})
    </insert>

    <update id="update" parameterType="org.example.project.sample.entity.SampleEntity">
        UPDATE SAMPLE_TABLE SET NAME=#{name}, EMAIL=#{email} WHERE ID=#{id}
    </update>

    <delete id="delete" parameterType="int">
        DELETE FROM SAMPLE_TABLE WHERE ID=#{id}
    </delete>

    <select id="findAllForSampleMember" resultType="org.example.project.sample.entity.SampleMemberEntity">
        SELECT * FROM SAMPLE_MEMBER_EXCEL ORDER BY ID
    </select>

</mapper>
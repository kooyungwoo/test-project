<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.project.sampleform.mapper.SampleFormMapper">

    <select id="findAll" resultType="org.example.project.sampleform.entity.SampleFormEntity">
        SELECT * FROM sample_form
    </select>

    <select id="findById" parameterType="int" resultType="org.example.project.sampleform.entity.SampleFormEntity">
        SELECT * FROM sample_form WHERE data_id = #{dataId}
    </select>

    <insert id="insert" parameterType="org.example.project.sampleform.entity.SampleFormEntity" useGeneratedKeys="true"
            keyProperty="dataId">
        INSERT INTO sample_form (title, content, status, printable, reg_date, mod_date)
        VALUES (#{title}, #{content}, #{status}, #{printable}, NOW(), NOW())
    </insert>

    <update id="update" parameterType="org.example.project.sampleform.entity.SampleFormEntity">
        UPDATE sample_form
        SET title = #{title}
        , content = #{content}
        , status = #{status}
        , printable = #{printable}
        , mod_date = NOW()
        WHERE data_id = #{dataId}
    </update>

    <delete id="delete" parameterType="int">
        DELETE FROM sample_form WHERE data_id = #{dataId}
    </delete>

</mapper>